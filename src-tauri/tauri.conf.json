{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PI WEB",
  "version": "0.1.0",
  "identifier": "com.pi-web.desktop",
  "build": {
    "frontendDist": "../pi-web-New-UI-/dist",
    "beforeDevCommand": "cd ../pi-web-New-UI-/ && npm run dev:client",
    "beforeBuildCommand": "cd ../pi-web-New-UI-/ && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "PI WEB",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false,
        "minWidth": 800,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis",
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
